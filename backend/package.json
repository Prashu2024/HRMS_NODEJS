{
    "name": "hrms-lite-api",
    "version": "1.0.0",
    "description": "HRMS Lite API - Node.js/TypeScript equivalent of FastAPI backend",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix"
    },
    "dependencies": {
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.36.3",
        "bcrypt": "^5.1.1",
        "better-sqlite3": "^9.6.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.5.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.12.0",
        "uuid": "^10.0.0",
        "winston": "^3.14.2",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/better-sqlite3": "^7.6.11",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^22.5.0",
        "@types/pg": "^8.11.8",
        "@types/uuid": "^10.0.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.5.4"
    }
}
