# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── SQLite Database ──────────────────────────────────────────────────────────
SQLITE_DB_PATH=data/hrms.db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5172,https://hrms-lemon-one.vercel.app

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs


# # HRMS Lite Backend Environment Variables

# # Database Configuration
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hrms_db

# # CORS Configuration (comma-separated origins)
# CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
